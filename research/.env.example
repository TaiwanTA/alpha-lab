# Postgres
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgres://alpha:change-me@localhost:5432/alpha_lab

# X API(到 https://developer.x.com 申請 bearer token)
X_BEARER_TOKEN=your-bearer-token-here

# Pipeline
RAW_ROOT=../raw
SOURCES_PATH=./sources.json

# LLM (OpenRouter — 支援多 provider,詳見 https://openrouter.ai)
LLM_API_KEY=your-openrouter-api-key
LLM_MODEL=minimax/minimax-m3
LLM_BASE_URL=https://openrouter.ai/api/v1

# Hindsight API(VM 上跑的 hindsight container;C agent 用)
HINDSIGHT_BASE_URL=http://localhost:8888

# Logging
LOG_DIR=./logs
LOG_CONSOLE=true   # 設 false 在 systemd 下停用 console,只寫檔

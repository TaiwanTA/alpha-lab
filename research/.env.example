# Postgres
POSTGRES_PASSWORD=change-me
# 注意:本機 dev 若 5432 已被佔用,docker-compose.yml 改 127.0.0.1:5433:5432,
# 此處也要同步改成 localhost:5433。Production VM 上 5432 沒衝突就用 5432。
DATABASE_URL=postgres://alpha:change-me@localhost:5432/alpha_lab

# X API(到 https://developer.x.com 申請 bearer token)
X_BEARER_TOKEN=your-bearer-token-here

# Pipeline
RAW_ROOT=../raw
SOURCES_PATH=./sources.json

# LLM (OpenRouter — 支援多 provider,詳見 https://openrouter.ai)
LLM_API_KEY=your-openrouter-api-key
LLM_MODEL=minimax/minimax-m3
LLM_BASE_URL=https://openrouter.ai/api/v1

# Hindsight API(VM 上跑的 hindsight container;C agent 用)
HINDSIGHT_BASE_URL=http://localhost:8888

# Logging
LOG_DIR=./logs
LOG_CONSOLE=true   # 設 false 在 systemd 下停用 console,只寫檔

# Vercel Workflow runtime (ADR-001 Step 7b)
WORKFLOW_POSTGRES_URL=postgres://alpha:change-me@localhost:5432/alpha_lab
WORKFLOW_TARGET_WORLD=@workflow/world-postgres
WORKFLOW_SERVER_PORT=8090
WORKFLOW_LOCAL_BASE_URL=http://127.0.0.1:8090   # workflow queue worker call back 給 server 的 base URL

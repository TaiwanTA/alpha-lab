{
  "compilerOptions": {
    "types": ["bun"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext"],
    "target": "ESNext",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "noUncheckedIndexedAccess": true,
    "resolveJsonModule": true
  },
  "include": ["**/*.ts", "**/*.json"]
}

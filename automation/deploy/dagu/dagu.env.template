# /etc/alpha-lab/dagu.env template — VM 實際環境變數檔的 placeholder。
#
# 這個檔是 template,值留空。setup-vm.sh 第一次跑時從
# GitHub Secrets / VM 備份 / 使用者互動讀入實際值,生成
# /etc/alpha-lab/dagu.env (mode 0440 root:alpha-lab-dagu)。
#
# 不要把實際值 commit 到 repo,所有值都是 secret。
#
# 對應的 consumer:
#   - dagu container (走 env_file 載入):dagu 內部跟 dagu step
#     都可以讀到。HINDSIGHT_* 給 dagu 內部跟 step 用,GIT_READ_TOKEN
#     給 dags-sync sidecar 的 git pull 用,Phase 4 secret (DATABASE_URL
#     / MINIMAX_API_KEY / X_BEARER_TOKEN / TWELVE_DATA_API_KEY) 給
#     migrate-phase4.ts + research-agent + capture + settlement workers。
#   - dags-sync sidecar (走 env_file 載入):讀 GIT_READ_TOKEN
#     跟 HINDSIGHT_*。實際上 sidecar 只用 SSH deploy key
#     (不靠 GIT_READ_TOKEN),所以這個 token 在 sidecar
#     是 dead — 保留是為了將來備援。

# Hindsight API endpoint (從容器內走) — 走同一個 docker
# network 的 container name,不是 host loopback。
HINDSIGHT_BASE_URL=

# Container name for hostname binding,跟 docker network alias 一致。
NAME=alpha-lab-dagu

# Hindsight API key (self-hosted Hindsight 不需要,留空)。
# 曾經用過的格式是 hindsight_xxx,但 2026-07 改 self-hosted 後
# 不用了。留 key 供將來切回 SaaS Hindsight。
HINDSIGHT_API_KEY=

# GitHub fine-grained PAT — 給 dags-sync sidecar git pull
# automation/dags/ 用的備援 auth (主要走 SSH deploy key)。
# PAT 要有 Contents: Read-only 權限,scope 限 TaiwanTA/alpha-lab。
# dags-sync.sh 用 HTTPS BasicAuth 走 `oauth2:<token>` header。
GIT_READ_TOKEN=

# GitHub fine-grained PAT,供 blog-publish DAG 的 `gh pr create` 使用。
# 只需要 TaiwanTA/alpha-lab 的 Contents: Read 和 Pull requests: Write,
# branch 推送继续使用 SSH deploy key。
GH_PR_TOKEN=

# Phase 4 event-ledger runtime contract.
#
# DATABASE_URL — Postgres connection string used by Phase 4 workers
# (calibrate / ingest / research / settlement) AND by
# migrate-phase4.ts. The dagu container joins the `research_default`
# docker network (see deploy/dagu/docker-compose.yml), so it resolves
# `alpha-lab-postgres` via Docker's embedded DNS to the postgres
# container's IP on that network. Inside `alpha-lab-postgres` itself,
# the role / database / password are set by the POSTGRES_USER /
# POSTGRES_DB / POSTGRES_PASSWORD env vars of the research stack
# (current values: user=alpha, db=alpha_lab). Format:
#   postgres://alpha:<password>@alpha-lab-postgres:5432/alpha_lab
DATABASE_URL=
#
# MINIMAX_API_KEY — LLM API key (OpenAI-compatible protocol,
# MiniMax M-series). research-agent.ts consumes it.
MINIMAX_API_KEY=
X_BEARER_TOKEN=
TWELVE_DATA_API_KEY=
---
import Layout from '../layouts/Layout.astro';
import { getAllInvestors, getAllTags, getPublishedPosts, STATUS_LABELS } from '../lib/posts';

const posts = await getPublishedPosts();
const tags = getAllTags(posts);
const investors = getAllInvestors(posts);
const sortedByInvestorCount = [...investors.entries()].sort((a, b) => b[1].length - a[1].length).slice(0, 5);
---

<Layout title="alpha-lab — 知名投資人研究">
  <section class="hero">
    <div class="hero-eyebrow">
      <span class="hero-dot"></span>
      <span>research · open sources · openly checked</span>
    </div>
    <h1>alpha-lab</h1>
    <p class="hero-lede">研究公開投資人的言論、論點、與決策。<br />每一篇明示來源,可重複查證,或標為未驗證。</p>

    <ul class="hero-stats">
      <li><span class="stat-num">{posts.length}</span><span class="stat-label">篇文章</span></li>
      <li><span class="stat-num">{tags.size}</span><span class="stat-label">個主題</span></li>
      <li><span class="stat-num">{investors.size}</span><span class="stat-label">位追蹤投資人</span></li>
    </ul>
  </section>

  <div class="home-grid">
    <section class="posts-section">
      <header class="section-header">
        <h2>最新文章</h2>
        <a href="/archive/" class="section-link">完整 archive →</a>
      </header>

      <ol class="post-list">
        {posts.map(post => (
          <li class={`post-card status-${post.data.status}`}>
            <article>
              <header class="post-card-head">
                <a href={`/posts/${post.id}/`} class="post-card-title">{post.data.title}</a>
                <span class={`status-pill status-${post.data.status}`} title={STATUS_LABELS[post.data.status]?.hex ?? ''}>
                  <span class="pill-dot"></span>
                  {STATUS_LABELS[post.data.status]?.label ?? post.data.status}
                </span>
              </header>

              <p class="post-card-summary">{post.data.summary}</p>

              <footer class="post-card-foot">
                <time datetime={post.data.date}>{post.data.date}</time>
                {post.data.investors.map((inv: string) => (
                  <a class="meta-link investor-link" href={`/investors/${encodeURIComponent(inv)}/`}>{inv}</a>
                ))}
                {post.data.tags.map((t: string) => (
                  <a class="meta-link tag-link" href={`/tags/${encodeURIComponent(t)}/`}>#{t}</a>
                ))}
              </footer>
            </article>
          </li>
        ))}
      </ol>
    </section>

    <aside class="side">
      <section class="side-block">
        <h3>熱門 Tags</h3>
        <ul class="tag-cloud">
          {[...tags.entries()].slice(0, 8).map(([tag, count]) => (
            <li><a href={`/tags/${encodeURIComponent(tag)}/`}><span class="tag-name">#{tag}</span><span class="tag-count">{count}</span></a></li>
          ))}
          {tags.size > 8 && <li><a class="see-all" href="/tags/">全部 {tags.size} tags →</a></li>}
        </ul>
      </section>

      <section class="side-block">
        <h3>追蹤的投資人</h3>
        <ul class="investor-list">
          {sortedByInvestorCount.map(([inv, list]) => (
            <li>
              <a href={`/investors/${encodeURIComponent(inv)}/`} class="investor-name">{inv}</a>
              <span class="investor-count">{list.length} 篇</span>
            </li>
          ))}
          {investors.size > 5 && <li><a class="see-all" href="/investors/">全部 →</a></li>}
        </ul>
      </section>

      <section class="side-block subscribe-block">
        <h3>訂閱</h3>
        <p class="subscribe-blurb">本站會每天更新(目標)。RSS 是最可靠的訂閱管道。</p>
        <ul class="subscribe-list">
          <li><a href="/feed.xml" class="sub-link"><strong>RSS</strong><span class="sub-hint">日常 reader</span></a></li>
          <li><a href="/feed.atom.xml" class="sub-link"><strong>Atom</strong><span class="sub-hint">Akregator 用</span></a></li>
          <li><a href="/feed.json" class="sub-link"><strong>JSON Feed</strong><span class="sub-hint">automation</span></a></li>
        </ul>
      </section>
    </aside>
  </div>
</Layout>

<style>
  /* ─────── Hero ─────── */
  .hero {
    padding: 3.5rem 0 4rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 4rem;
  }
  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    color: var(--color-fg-muted);
    margin-bottom: 1.5rem;
    text-transform: lowercase;
  }
  .hero-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-accent-2);
    box-shadow: 0 0 0 4px var(--color-accent-tint);
    animation: pulse 2.4s ease-in-out infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }

  .hero h1 {
    font-family: var(--font-sans);
    font-size: clamp(2.5rem, 6vw, 3.5rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1;
    margin: 0 0 1.25rem;
    color: var(--color-fg);
  }
  .hero-lede {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: clamp(1.15rem, 2vw, 1.35rem);
    line-height: 1.55;
    color: var(--color-fg-2);
    margin: 0 0 2rem;
    max-width: 38ch;
    letter-spacing: -0.005em;
  }

  .hero-stats {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .hero-stats li {
    display: inline-flex;
    align-items: baseline;
    gap: 0.4rem;
    padding: 0.5rem 0.9rem;
    background: var(--color-bg-2);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    transition: background-color 150ms ease, border-color 150ms ease, transform 150ms ease;
  }
  .hero-stats li:hover {
    background: var(--color-bg-3);
    border-color: var(--color-border-2);
    transform: translateY(-1px);
  }
  .stat-num {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--color-fg);
  }
  .stat-label {
    font-size: 0.85rem;
    color: var(--color-fg-muted);
  }

  /* ─────── Grid ─────── */
  .home-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
  }
  @media (min-width: 1024px) {
    .home-grid {
      grid-template-columns: minmax(0, 1fr) 280px;
      gap: 5rem;
    }
  }

  .section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 1.5rem;
  }
  .section-header h2 {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin: 0;
    color: var(--color-fg);
  }
  .section-link {
    font-size: 0.85rem;
    color: var(--color-link);
    text-decoration: none;
    white-space: nowrap;
  }

  /* ─────── Post cards ─────── */
  .post-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .post-card {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 1.5rem 1.75rem;
    transition: transform 180ms cubic-bezier(0.4, 0, 0.2, 1), box-shadow 180ms ease, border-color 180ms ease;
  }
  .post-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-card-hover);
    border-color: var(--color-border-2);
  }
  .post-card.status-unverified {
    border-left: 3px solid #d97706;
  }
  .post-card.status-verified {
    border-left: 3px solid #15803d;
  }
  .post-card.status-corrected {
    border-left: 3px solid #2563eb;
  }
  .post-card.status-draft {
    border-left: 3px solid var(--color-fg-subtle);
    opacity: 0.85;
  }

  .post-card-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 0.5rem;
  }
  .post-card-title {
    font-family: var(--font-serif);
    font-size: 1.35rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.3;
    color: var(--color-fg);
    text-decoration: none;
    view-transition-name: post-title;
  }
  .post-card-title:hover { color: var(--color-accent-2); text-decoration: none; }

  .status-pill {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.2rem 0.55rem;
    border-radius: 100px;
    font-size: 0.7rem;
    font-weight: 500;
    text-transform: lowercase;
    letter-spacing: 0.04em;
  }
  .pill-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: currentColor;
  }
  .status-pill.status-unverified { background: #fef3c7; color: #92400e; }
  .status-pill.status-verified   { background: #dcfce7; color: #14532d; }
  .status-pill.status-draft      { background: #f3f4f6; color: #4b5563; }
  .status-pill.status-corrected  { background: #dbeafe; color: #1e3a8a; }
  @media (prefers-color-scheme: dark) {
    .status-pill.status-unverified { background: #422006; color: #fde68a; }
    .status-pill.status-verified   { background: #052e1a; color: #86efac; }
    .status-pill.status-draft      { background: #1f2937; color: #d1d5db; }
    .status-pill.status-corrected  { background: #1e293b; color: #93c5fd; }
  }

  .post-card-summary {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    line-height: 1.6;
    color: var(--color-fg-2);
    margin: 0.5rem 0 1rem;
  }

  .post-card-foot {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1rem;
    align-items: center;
    font-size: 0.8rem;
    color: var(--color-fg-muted);
  }
  .post-card-foot time { font-variant-numeric: tabular-nums; }
  .meta-link {
    color: var(--color-fg-muted);
    text-decoration: none;
    transition: color 120ms ease;
  }
  .meta-link:hover { color: var(--color-accent-2); text-decoration: none; }
  .investor-link::before { content: '◆ '; color: var(--color-accent-2); font-size: 0.65rem; }
  .tag-link { color: var(--color-fg-subtle); }

  /* ─────── Side ─────── */
  .side-block { margin-bottom: 2.5rem; }
  .side-block h3 {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-fg-muted);
    margin: 0 0 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .tag-cloud {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .tag-cloud a {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 0.25rem 0;
    text-decoration: none;
    color: var(--color-fg-2);
    transition: color 120ms ease, padding 120ms ease;
  }
  .tag-cloud a:hover { color: var(--color-accent-2); padding-left: 0.25rem; text-decoration: none; }
  .tag-name { font-family: var(--font-mono); font-size: 0.85rem; }
  .tag-count { font-size: 0.75rem; color: var(--color-fg-subtle); font-variant-numeric: tabular-nums; }

  .investor-list { list-style: none; padding: 0; margin: 0; }
  .investor-list li {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 0.4rem 0;
    border-bottom: 1px dashed var(--color-border);
  }
  .investor-list li:last-child { border-bottom: none; }
  .investor-name {
    font-family: var(--font-serif);
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-fg);
    text-decoration: none;
  }
  .investor-name:hover { color: var(--color-accent-2); }
  .investor-count {
    font-size: 0.75rem;
    color: var(--color-fg-subtle);
    font-variant-numeric: tabular-nums;
  }

  .see-all {
    display: inline-block;
    margin-top: 0.6rem;
    font-size: 0.85rem;
    color: var(--color-accent-2);
  }

  .subscribe-blurb {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 0.9rem;
    color: var(--color-fg-muted);
    margin: 0 0 1rem;
  }
  .subscribe-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.4rem; }
  .sub-link {
    display: flex;
    flex-direction: column;
    padding: 0.6rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: background-color 120ms ease, border-color 120ms ease;
  }
  .sub-link:hover {
    background: var(--color-accent-tint);
    border-color: var(--color-accent-2);
    text-decoration: none;
  }
  .sub-link strong { font-family: var(--font-mono); color: var(--color-fg); font-weight: 500; font-size: 0.95rem; }
  .sub-hint { font-size: 0.75rem; color: var(--color-fg-subtle); }
</style>

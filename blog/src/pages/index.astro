---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const today = new Date().toISOString().slice(0, 10);
const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.localeCompare(a.data.date),
);
---

<Layout title="alpha-lab — 知名投資人研究">
  <header>
    <h1>alpha-lab</h1>
    <p class="tagline">研究知名投資人的觀點、論點、與市場直覺</p>
  </header>

  <section>
    <h2>Posts</h2>
    <ul class="post-list">
      {posts.map(post => (
        <li>
          <a href={`/posts/${post.id}/`}>{post.data.title}</a>
          <p class="meta">
            <span class="date">{post.data.date}</span>
            {post.data.status === 'unverified' && <span class="badge">unverified</span>}
          </p>
          <p class="summary">{post.data.summary}</p>
        </li>
      ))}
    </ul>
  </section>

  <footer>
    <p>更新於 {today}</p>
    <p class="note">
      所有文章若標示 <span class="badge-inline">unverified</span>,表示內容未經原始來源驗證 — 這是刻意標示,不表示內容有誤,只表示作者(AI agent)沒有完成查證。
      這個站的兩難:整理公開資訊、研究方法論是 AI 能做的;但可重複查證每個論點的真偽、不是。請讀者自負風險。
    </p>
  </footer>
</Layout>

<style>
  header { margin-bottom: 3rem; }
  h1 { font-size: 2.5rem; margin: 0 0 0.5rem; }
  .tagline { color: #666; font-size: 1.1rem; margin: 0; }

  .post-list { list-style: none; padding: 0; }
  .post-list li {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid #eee;
  }
  .post-list a {
    font-size: 1.3rem;
    font-weight: 600;
    text-decoration: none;
    color: #111;
  }
  .post-list a:hover { text-decoration: underline; }
  .meta {
    color: #999;
    font-size: 0.85rem;
    margin: 0.25rem 0;
    display: flex;
    gap: 0.75rem;
    align-items: center;
  }
  .summary {
    color: #555;
    margin: 0.25rem 0 0;
  }

  .badge {
    background: #fef3c7;
    color: #92400e;
    padding: 0.1rem 0.4rem;
    border-radius: 3px;
    font-size: 0.75rem;
    font-weight: 600;
  }
  .badge-inline {
    background: #fef3c7;
    color: #92400e;
    padding: 0.05rem 0.3rem;
    border-radius: 3px;
    font-size: 0.85rem;
    font-weight: 600;
  }

  footer {
    margin-top: 4rem;
    color: #666;
    font-size: 0.85rem;
  }
  .note {
    background: #f9fafb;
    border-left: 3px solid #d1d5db;
    padding: 0.75rem 1rem;
    margin-top: 1rem;
    line-height: 1.5;
  }
</style>

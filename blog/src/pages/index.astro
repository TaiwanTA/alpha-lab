---
import type { Post } from '../lib/posts';
import Layout from '../layouts/Layout.astro';
import { getAllInvestors, getAllTags, getPublishedPosts, STATUS_LABELS } from '../lib/posts';

const posts = await getPublishedPosts();
const tags = getAllTags(posts);
const investors = getAllInvestors(posts);
const sortedTags = [...tags.entries()].sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]));
const sortedInvestors = [...investors.entries()].sort((a, b) => b[1].length - a[1].length || a[0].localeCompare(b[0]));

type PostWithOptionalCover = Post & { data: Post['data'] & { coverImage?: string } };
const getCoverImage = (post: Post) => (post as PostWithOptionalCover).data.coverImage;
---

<Layout title="alpha-lab — 知名投資人研究">
  <section class="hub-hero">
    <div class="hero-copy">
      <p class="hero-eyebrow"><span class="hero-dot" aria-hidden="true"></span> research · open sources · openly checked</p>
      <h1>alpha-lab</h1>
      <p class="hero-lede">研究公開投資人的言論、論點、與決策。每一篇明示來源,可重複查證,或標為未驗證。</p>
      <div class="hero-actions">
        <a href="/archive" class="button button-primary">瀏覽完整 archive <span aria-hidden="true">→</span></a>
        <a href="/methodology" class="button button-quiet">了解研究方法</a>
      </div>
    </div>

    <dl class="hero-stats">
      <div><dt>{posts.length}</dt><dd>篇文章</dd></div>
      <div><dt>{tags.size}</dt><dd>個主題</dd></div>
      <div><dt>{investors.size}</dt><dd>位投資人</dd></div>
    </dl>
  </section>

  <div class="hub-layout">
    <aside class="filters" aria-label="文章篩選">
      <section class="filter-group">
        <div class="filter-heading">
          <h2>投資人</h2>
          <span>{investors.size}</span>
        </div>
        <ul class="filter-list">
          {sortedInvestors.map(([investor, list]) => (
            <li>
              <a class="filter-link" href={`/investors/${encodeURIComponent(investor)}`}>
                <span>{investor}</span>
                <span class="filter-badge">{list.length}</span>
              </a>
            </li>
          ))}
        </ul>
      </section>

      <section class="filter-group">
        <div class="filter-heading">
          <h2>標籤</h2>
          <span>{tags.size}</span>
        </div>
        <ul class="filter-list">
          {sortedTags.map(([tag, count]) => (
            <li>
              <a class="filter-link" href={`/tags/${encodeURIComponent(tag)}`}>
                <span>#{tag}</span>
                <span class="filter-badge">{count}</span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    </aside>

    <section class="posts-panel" aria-labelledby="latest-heading">
      <header class="posts-header">
        <div>
          <p class="section-kicker">Editorial desk</p>
          <h2 id="latest-heading">最新文章</h2>
        </div>
        <a href="/archive" class="section-link">查看全部 <span aria-hidden="true">→</span></a>
      </header>

      {posts.length > 0 && (
        <div class="post-grid">
          {posts.map((post, index) => {
            const coverImage = getCoverImage(post);
            return (
              <article class={`post-card status-${post.data.status}`}>
                <a href={`/posts/${post.id}`} class="post-card-link">
                  <div class="post-card-media" class:list={{ 'card-placeholder': !coverImage }}>
                    {coverImage && <img src={coverImage} alt="" loading="lazy" />}
                    {!coverImage && <span aria-hidden="true">AL / {String(index + 1).padStart(2, '0')}</span>}
                  </div>

                  <div class="post-card-body">
                    <div class="tag-row">
                      {post.data.tags.slice(0, 3).map((tag: string) => <span class="tag-chip">#{tag}</span>)}
                      <span class={`status-pill status-${post.data.status}`}>
                        <span class="pill-dot" aria-hidden="true"></span>
                        {STATUS_LABELS[post.data.status]?.label ?? post.data.status}
                      </span>
                    </div>
                    <h3 class="post-card-title">{post.data.title}</h3>
                    <p class="post-card-excerpt">{post.data.summary}</p>
                    <div class="post-card-foot">
                      <time datetime={post.data.date}>{post.data.date}</time>
                      <span class="read-more">閱讀更多 <span aria-hidden="true">→</span></span>
                    </div>
                  </div>
                </a>
              </article>
            );
          })}
        </div>
      )}
      {posts.length === 0 && <p class="empty-state">目前沒有已發布的文章。</p>}
    </section>
  </div>
</Layout>

<style>
  /* 首頁導言 */
  .hub-hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: end;
    gap: 2.5rem;
    padding: clamp(1.5rem, 4vw, 3rem);
    margin-bottom: 2.75rem;
    background: linear-gradient(135deg, var(--color-accent-tint) 0%, var(--color-bg) 70%);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-card);
  }
  .hero-copy { max-width: 42rem; }
  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    margin: 0 0 1.25rem;
    color: var(--color-accent-2);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .hero-dot {
    width: 0.5rem;
    height: 0.5rem;
    flex: 0 0 auto;
    border-radius: 50%;
    background: var(--color-accent);
    box-shadow: 0 0 0 5px var(--color-accent-soft);
  }
  .hub-hero h1 {
    margin: 0 0 0.85rem;
    color: var(--color-fg);
    font-family: var(--font-sans);
    font-size: clamp(2.5rem, 7vw, 4.5rem);
    font-weight: 800;
    letter-spacing: -0.06em;
    line-height: 0.95;
  }
  .hero-lede {
    max-width: 38rem;
    margin: 0;
    color: var(--color-fg-2);
    font-family: var(--font-serif);
    font-size: clamp(1rem, 2vw, 1.2rem);
    line-height: 1.65;
  }
  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }
  .button {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    min-height: 2.5rem;
    padding: 0.55rem 0.95rem;
    border-radius: var(--radius-md);
    font-size: 0.85rem;
    font-weight: 600;
    text-decoration: none;
    transition: transform 150ms ease, background-color 150ms ease, border-color 150ms ease, color 150ms ease;
  }
  .button:hover { transform: translateY(-1px); text-decoration: none; }
  .button-primary { background: var(--color-accent-2); color: white; }
  .button-primary:hover { background: var(--color-link-hover); color: white; }
  .button-quiet { border: 1px solid var(--color-border-2); color: var(--color-fg-2); }
  .button-quiet:hover { border-color: var(--color-accent); background: var(--color-bg); color: var(--color-accent-2); }
  .hero-stats {
    display: grid;
    grid-template-columns: repeat(3, minmax(4.5rem, 1fr));
    gap: 0.65rem;
    min-width: 15rem;
    margin: 0;
  }
  .hero-stats div {
    padding: 0.8rem 0.75rem;
    background: color-mix(in srgb, var(--color-bg) 72%, transparent);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    text-align: center;
  }
  .hero-stats dt {
    color: var(--color-accent-2);
    font-size: 1.35rem;
    font-weight: 800;
    line-height: 1.2;
  }
  .hero-stats dd {
    margin: 0.25rem 0 0;
    color: var(--color-fg-muted);
    font-size: 0.72rem;
    white-space: nowrap;
  }

  /* Hub 佈局與篩選 */
  .hub-layout {
    display: grid;
    grid-template-columns: 220px minmax(0, 1fr);
    gap: 2.5rem;
    align-items: start;
  }
  .filters {
    position: sticky;
    top: 5.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .filter-group {
    padding: 1rem;
    background: var(--color-bg-2);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-card);
  }
  .filter-heading {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    margin-bottom: 0.65rem;
    padding-bottom: 0.65rem;
    border-bottom: 1px solid var(--color-border);
  }
  .filter-heading h2 {
    margin: 0;
    color: var(--color-fg);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.04em;
  }
  .filter-heading > span {
    color: var(--color-fg-subtle);
    font-family: var(--font-mono);
    font-size: 0.68rem;
  }
  .filter-list {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    max-height: 26rem;
    margin: 0;
    padding: 0;
    overflow-y: auto;
    list-style: none;
  }
  .filter-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    padding: 0.42rem 0.45rem;
    border-radius: var(--radius-sm);
    color: var(--color-fg-2);
    font-size: 0.84rem;
    text-decoration: none;
    transition: background-color 120ms ease, color 120ms ease;
  }
  .filter-link:hover {
    background: var(--color-accent-tint);
    color: var(--color-accent-2);
    text-decoration: none;
  }
  .filter-badge {
    min-width: 1.7rem;
    padding: 0.1rem 0.4rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-pill);
    background: var(--color-bg);
    color: var(--color-fg-muted);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    line-height: 1.3;
    text-align: center;
    font-variant-numeric: tabular-nums;
  }

  /* 文章區 */
  .posts-panel { min-width: 0; }
  .posts-header {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.25rem;
  }
  .section-kicker {
    margin: 0 0 0.25rem;
    color: var(--color-accent-2);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .posts-header h2 {
    margin: 0;
    color: var(--color-fg);
    font-size: 1.6rem;
    font-weight: 750;
    letter-spacing: -0.04em;
  }
  .section-link {
    flex-shrink: 0;
    color: var(--color-link);
    font-size: 0.82rem;
    font-weight: 600;
    text-decoration: none;
  }
  .section-link:hover { color: var(--color-link-hover); text-decoration: none; }
  .post-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 1.35rem;
  }
  .post-card {
    min-width: 0;
    overflow: hidden;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-card);
    transition: transform 180ms cubic-bezier(0.4, 0, 0.2, 1), box-shadow 180ms ease, border-color 180ms ease;
  }
  .post-card:hover {
    transform: translateY(-2px);
    border-color: var(--color-accent);
    box-shadow: var(--shadow-card-hover);
  }
  .post-card-link {
    display: flex;
    flex-direction: column;
    height: 100%;
    color: inherit;
    text-decoration: none;
  }
  .post-card-link:hover { color: inherit; text-decoration: none; }
  .post-card-media {
    position: relative;
    height: 9.5rem;
    overflow: hidden;
    background: var(--color-bg-3);
  }
  .post-card-media img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 300ms ease;
  }
  .post-card:hover .post-card-media img { transform: scale(1.03); }
  .card-placeholder {
    display: grid;
    place-items: center;
    background: linear-gradient(125deg, var(--color-accent) 0%, var(--color-accent-2) 58%, #c084fc 100%);
  }
  .card-placeholder span {
    color: rgb(255 255 255 / 0.78);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
  }
  .post-card-body {
    display: flex;
    flex: 1;
    flex-direction: column;
    padding: 1.05rem 1.15rem 1.15rem;
  }
  .tag-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.35rem;
    min-height: 1.45rem;
    margin-bottom: 0.7rem;
  }
  .tag-chip {
    padding: 0.18rem 0.52rem;
    border: 1px solid var(--color-accent-soft);
    border-radius: var(--radius-pill);
    background: var(--color-accent-tint);
    color: var(--color-accent-2);
    font-family: var(--font-mono);
    font-size: 0.66rem;
    line-height: 1.3;
  }
  .status-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    margin-left: auto;
    padding: 0.18rem 0.5rem;
    border-radius: var(--radius-pill);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    white-space: nowrap;
  }
  .pill-dot { width: 0.35rem; height: 0.35rem; border-radius: 50%; background: currentColor; }
  .status-pill.status-unverified { background: #fef3c7; color: #92400e; }
  .status-pill.status-verified { background: #dcfce7; color: #14532d; }
  .status-pill.status-draft { background: #f3f4f6; color: #4b5563; }
  .status-pill.status-corrected { background: #dbeafe; color: #1e3a8a; }
  .post-card-title {
    display: -webkit-box;
    margin: 0;
    overflow: hidden;
    color: var(--color-fg);
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.35;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }
  .post-card:hover .post-card-title { color: var(--color-accent-2); }
  .post-card-excerpt {
    display: -webkit-box;
    margin: 0.65rem 0 1.1rem;
    overflow: hidden;
    color: var(--color-fg-muted);
    font-family: var(--font-serif);
    font-size: 0.93rem;
    line-height: 1.55;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
  }
  .post-card-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-top: auto;
    padding-top: 0.8rem;
    border-top: 1px solid var(--color-border);
    color: var(--color-fg-subtle);
    font-size: 0.72rem;
  }
  .post-card-foot time { font-variant-numeric: tabular-nums; }
  .read-more { color: var(--color-link); font-weight: 600; }
  .empty-state {
    margin: 0;
    padding: 2rem;
    border: 1px dashed var(--color-border-2);
    border-radius: var(--radius-lg);
    color: var(--color-fg-muted);
    text-align: center;
  }

  @media (max-width: 767px) {
    .hub-hero {
      grid-template-columns: 1fr;
      gap: 1.75rem;
      margin-bottom: 2rem;
    }
    .hero-stats { min-width: 0; }
    .hub-layout { grid-template-columns: 1fr; gap: 2rem; }
    .filters {
      position: static;
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.75rem;
    }
    .filter-group { padding: 0.8rem; }
    .filter-list { max-height: 16rem; }
    .post-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 480px) {
    .filters { grid-template-columns: 1fr; }
    .hub-hero h1 { font-size: 3rem; }
  }
</style>

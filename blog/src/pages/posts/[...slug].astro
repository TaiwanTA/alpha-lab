---
import type { Post } from '../../lib/posts';
import { render } from 'astro:content';
import readingTime from 'reading-time';
import Layout from '../../layouts/Layout.astro';
import { formatDate, getPublishedPosts, STATUS_LABELS } from '../../lib/posts';
import { buildToc } from '../../lib/toc';

interface Props {
  post: Post;
  prev: Post | null;
  next: Post | null;
}

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  const ascByDate = [...posts].sort((a, b) => a.data.date.localeCompare(b.data.date));
  return posts.map((post, i) => ({
    params: { slug: post.id },
    props: {
      post,
      prev: ascByDate[i - 1] ?? null,
      next: ascByDate[i + 1] ?? null,
    },
  }));
}

const { post, prev, next } = Astro.props as Props;
const { Content, headings } = await render(post);
const stats = readingTime(post.body ?? '');
const toc = buildToc(headings);
const isUnverified = post.data.status === 'unverified';
const statusInfo = STATUS_LABELS[post.data.status];
const lastmodLabel = post.data.lastmod ? formatDate(post.data.lastmod) : null;
const diffDays = post.data.lastmod
  ? Math.floor((new Date(post.data.lastmod).getTime() - new Date(post.data.date).getTime()) / 86400000)
  : 0;
const showLastmod = diffDays > 7;
---

<Layout title={post.data.title} description={post.data.summary} ogType="article" publishedDate={post.data.date} modifiedDate={post.data.lastmod ?? post.data.date} tags={post.data.tags}>
  <article class="post">
    <header class="post-header">
      <div class="post-status-row">
        <span class={`status-badge status-${post.data.status}`}>{statusInfo?.label ?? post.data.status}</span>
        <span class="post-date">{formatDate(post.data.date)}</span>
        {showLastmod && lastmodLabel && <span class="post-updated">最後更新於 {lastmodLabel}</span>}
      </div>
      <h1>{post.data.title}</h1>
      {post.data.summary && <p class="lede">{post.data.summary}</p>}
      <div class="post-meta">
        <span>📖 ~{Math.max(1, Math.round(stats.minutes))} 分鐘</span>
        <span>{stats.words.toLocaleString()} 字</span>
        {post.data.investors.length > 0 && <span class="meta-investors">提及:{post.data.investors.map((inv: string) => <a href={`/investors/${encodeURIComponent(inv)}/`}>{inv}</a>)}</span>}
        <a class="meta-tag-link" href="/tags/">Tags:</a>
        {post.data.tags.map((t: string) => <a class="meta-tag" href={`/tags/${encodeURIComponent(t)}/`}>#{t}</a>)}
      </div>
    </header>

    <div class="post-grid">
      {toc.length > 1 && (
        <aside class="toc" aria-label="目錄">
          <details open>
            <summary>目錄</summary>
            <ol>
              {toc.map(h => <li class={`depth-${h.depth}`}><a href={`#${h.slug}`}>{h.text}</a></li>)}
            </ol>
          </details>
        </aside>
      )}

      <div class="post-body">
        {isUnverified && (
          <div class="banner"><strong>風格示範 / 未驗證</strong> — 這篇文章的具體事實來自 LLM 內建知識,未經原始來源驗證。作為研究示範看風格就好,不應作為投資依據。</div>
        )}

        <Content />

        {post.data.investmentClaim && (
          <div class="disclosure"><strong>免責聲明</strong> — 本文涉及對投資人論點/持倉的討論,<strong>不構成投資建議</strong>。所有從該投資人之公開行為推論的「如果我下注」內容,僅是研究方法的展示,非可執行的策略。讀者須自行查證原始來源、自負投資風險。</div>
        )}

        <nav class="prev-next" aria-label="文章導航">
          {prev ? <a class="prev" href={`/posts/${prev.id}/`}><span class="dir">← 上一篇</span><span class="title">{prev.data.title}</span></a> : <span></span>}
          {next ? <a class="next" href={`/posts/${next.id}/`}><span class="dir">下一篇 →</span><span class="title">{next.data.title}</span></a> : <span></span>}
        </nav>

        <div class="post-share">
          <span>分享:</span>
          <a href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(post.data.title)}&url=${encodeURIComponent(new URL(`/posts/${post.id}/`, Astro.site).toString())}`} rel="noopener" target="_blank">X / Twitter</a>
          <button class="copy-link-btn" data-copy-url={new URL(`/posts/${post.id}/`, Astro.site).toString()} type="button">複製連結</button>
        </div>

        <p class="post-history">發佈於 {formatDate(post.data.date)}{post.data.lastmod && ` · 最後更新於 ${formatDate(post.data.lastmod)}`}</p>
      </div>
    </div>
  </article>
</Layout>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.copy-link-btn');
  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const url = btn.dataset.copyUrl || window.location.href;
      navigator.clipboard.writeText(url).then(
        () => {
          btn.textContent = '已複製 ✓';
          setTimeout(
            () => { btn.textContent = '複製連結'; },
            1500,
          );
        },
        () => { btn.textContent = '複製失敗'; },
      );
    });
  });
</script>

<style>
.post-header { margin-bottom: 2rem; padding-bottom: 1rem; border-bottom: 1px solid var(--color-border); }
.post-header h1 { font-size: 2.2rem; margin: 0.5rem 0 0.75rem; line-height: 1.25; }
.post-header .lede { color: var(--color-muted); font-size: 1.1rem; margin: 0 0 1rem; }
.post-status-row { display: flex; flex-wrap: wrap; gap: 0.75rem; align-items: center; font-size: 0.85rem; color: var(--color-muted); }
.status-badge { font-weight: 600; padding: 0.15rem 0.5rem; border-radius: 3px; }
.status-unverified { background: #fef3c7; color: #92400e; }
.status-verified { background: #dcfce7; color: #14532d; }
.status-draft { background: #f3f4f6; color: #374151; }
.status-corrected { background: #dbeafe; color: #1e40af; }
@media (prefers-color-scheme: dark) {
  .status-unverified { background: #422006; color: #fde68a; }
  .status-verified { background: #052e1a; color: #86efac; }
  .status-draft { background: #1f2937; color: #d1d5db; }
  .status-corrected { background: #1e293b; color: #93c5fd; }
}
.post-updated { font-style: italic; }
.post-meta { display: flex; flex-wrap: wrap; gap: 0.75rem 1rem; align-items: center; font-size: 0.9rem; color: var(--color-muted); }
.post-meta a { color: var(--color-link); text-decoration: none; }
.post-meta a:hover { text-decoration: underline; }
.meta-tag-link { margin-left: auto; }
.meta-tag { font-weight: 500; }
.post-grid { display: grid; grid-template-columns: 1fr; gap: 2rem; }
@media (min-width: 1024px) {
  .post-grid { grid-template-columns: 220px minmax(0, 1fr); align-items: start; }
  .toc { position: sticky; top: 1.5rem; max-height: calc(100vh - 3rem); overflow-y: auto; }
}
.toc { border: 1px solid var(--color-border); border-radius: 6px; background: var(--color-bg); font-size: 0.9rem; }
.toc summary { padding: 0.6rem 0.9rem; cursor: pointer; font-weight: 600; list-style: none; }
.toc summary::-webkit-details-marker { display: none; }
.toc ol { margin: 0; padding: 0.25rem 0.6rem 0.6rem 1.6rem; border-top: 1px solid var(--color-border); }
.toc li.depth-3 { padding-left: 0.8rem; }
.toc a { display: block; padding: 0.2rem 0; color: var(--color-muted); text-decoration: none; }
.toc a:hover { color: var(--color-fg); text-decoration: underline; }
.banner { background: #fff4e5; border-left: 4px solid #d97706; padding: 1rem 1.25rem; margin: 0 0 2rem; font-size: 0.95rem; color: #7c2d12; border-radius: 4px; }
@media (prefers-color-scheme: dark) { .banner { background: #422006; color: #fde68a; border-left-color: #f59e0b; } }
.disclosure { border: 1px solid var(--color-border); background: #f9fafb; padding: 1rem 1.25rem; margin: 2rem 0 0; font-size: 0.9rem; border-radius: 4px; }
@media (prefers-color-scheme: dark) { .disclosure { background: #1a1f2e; } }
.post-body :global(h2) { font-size: 1.5rem; margin: 2.5rem 0 1rem; padding-top: 0.5rem; scroll-margin-top: 1rem; }
.post-body :global(h3) { font-size: 1.2rem; margin: 1.5rem 0 0.5rem; scroll-margin-top: 1rem; }
.post-body :global(h1) { display: none; }
.post-body :global(p) { margin: 1rem 0; }
.post-body :global(ul), .post-body :global(ol) { padding-left: 1.5rem; }
.post-body :global(li) { margin: 0.25rem 0; }
.post-body :global(blockquote) { border-left: 3px solid var(--color-quote-border); padding-left: 1rem; margin: 1rem 0; color: var(--color-muted); }
.post-body :global(table) { border-collapse: collapse; width: 100%; margin: 1rem 0; font-size: 0.95rem; }
.post-body :global(th), .post-body :global(td) { border: 1px solid var(--color-border); padding: 0.5rem 0.75rem; text-align: left; }
.post-body :global(th) { background: #f9fafb; font-weight: 600; }
@media (prefers-color-scheme: dark) { .post-body :global(th) { background: #1a1f2e; } }
.post-body :global(code) { background: var(--color-code-bg); padding: 0.1rem 0.3rem; border-radius: 3px; font-size: 0.9em; }
.post-body :global(hr) { border: none; border-top: 1px solid var(--color-border); margin: 2rem 0; }
.prev-next { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin: 3rem 0 1rem; padding-top: 2rem; border-top: 1px solid var(--color-border); }
.prev-next .next { text-align: right; }
.prev-next a { display: block; padding: 0.75rem 1rem; border: 1px solid var(--color-border); border-radius: 6px; text-decoration: none; color: var(--color-fg); }
.prev-next a:hover { border-color: var(--color-link); }
.prev-next .dir { display: block; font-size: 0.85rem; color: var(--color-muted); margin-bottom: 0.25rem; }
.prev-next .title { font-weight: 600; }
.post-share { display: flex; flex-wrap: wrap; gap: 0.5rem 1rem; align-items: center; font-size: 0.9rem; padding: 1rem 0; margin: 2rem 0 0; border-top: 1px solid var(--color-border); }
.post-share a, .post-share button { background: transparent; border: 1px solid var(--color-border); color: var(--color-fg); padding: 0.25rem 0.6rem; border-radius: 4px; font-size: 0.85rem; cursor: pointer; text-decoration: none; }
.post-history { color: var(--color-muted); font-size: 0.85rem; margin-top: 2rem; }
@media print {
  nav.site-nav, footer, .toc, .post-share, .prev-next, .banner, .disclosure { display: none; }
  article { font-size: 11pt; line-height: 1.4; max-width: none; }
}
</style>

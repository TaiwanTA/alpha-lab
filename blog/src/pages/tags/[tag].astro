---
import type { Post } from '../../lib/posts';
import Layout from '../../layouts/Layout.astro';
import { getPublishedPosts, STATUS_LABELS } from '../../lib/posts';

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  const tagSet = new Set<string>();
  for (const post of posts) {
    for (const tag of post.data.tags) tagSet.add(tag);
  }
  return [...tagSet].map(tag => ({
    params: { tag },
    props: {
      tag,
      posts: posts.filter(post => post.data.tags.includes(tag)),
    },
  }));
}

const { tag, posts } = Astro.props;
type PostWithOptionalCover = Post & { data: Post['data'] & { coverImage?: string } };
const getCoverImage = (post: Post) => (post as PostWithOptionalCover).data.coverImage;
---

<Layout title={`#${tag} — alpha-lab`} description={`所有標記為 #${tag} 的文章`}>
  <header class="page-head">
    <nav class="breadcrumb" aria-label="麵包屑">
      <a href="/">Home</a>
      <span class="breadcrumb-sep">/</span>
      <a href="/tags">Tags</a>
      <span class="breadcrumb-sep">/</span>
      <span aria-current="page">#{tag}</span>
    </nav>
    <p class="page-kicker">Topic collection</p>
    <h1># {tag}</h1>
    <p class="lede">{posts.length} 篇文章</p>
  </header>

  <section class="results" aria-labelledby="results-heading">
    <header class="results-header">
      <h2 id="results-heading">這個主題的研究</h2>
      <a href="/tags" class="back-link">所有標籤 <span aria-hidden="true">→</span></a>
    </header>

    <div class="post-grid">
      {posts.map((post: Post, index: number) => {
        const coverImage = getCoverImage(post);
        return (
          <article class={`post-card status-${post.data.status}`}>
            <a href={`/posts/${post.id}`} class="post-card-link">
              <div class="post-card-media" class:list={{ 'card-placeholder': !coverImage }}>
                {coverImage && <img src={coverImage} alt="" loading="lazy" />}
                {!coverImage && <span aria-hidden="true">AL / {String(index + 1).padStart(2, '0')}</span>}
              </div>
              <div class="post-card-body">
                <div class="tag-row">
                  {post.data.tags.slice(0, 3).map((item: string) => <span class="tag-chip">#{item}</span>)}
                  <span class={`status-pill status-${post.data.status}`}>
                    <span class="pill-dot" aria-hidden="true"></span>
                    {STATUS_LABELS[post.data.status]?.label ?? post.data.status}
                  </span>
                </div>
                <h3 class="post-card-title">{post.data.title}</h3>
                <p class="post-card-excerpt">{post.data.summary}</p>
                <div class="post-card-foot">
                  <time datetime={post.data.date}>{post.data.date}</time>
                  <span class="read-more">閱讀更多 <span aria-hidden="true">→</span></span>
                </div>
              </div>
            </a>
          </article>
        );
      })}
    </div>
  </section>
</Layout>

<style>
  /* 頁首 */
  .page-head { margin-bottom: 2.5rem; }
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
    color: var(--color-fg-muted);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  .breadcrumb a { color: var(--color-fg-muted); text-decoration: none; }
  .breadcrumb a:hover { color: var(--color-accent-2); }
  .breadcrumb-sep { color: var(--color-fg-subtle); }
  .breadcrumb [aria-current] { color: var(--color-fg); }
  .page-kicker {
    margin: 0 0 0.4rem;
    color: var(--color-accent-2);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .page-head h1 {
    margin: 0 0 0.5rem;
    color: var(--color-fg);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.05em;
    line-height: 1.1;
  }
  .lede { margin: 0; color: var(--color-fg-muted); font-size: 1rem; }

  /* 文章卡片 */
  .results { min-width: 0; }
  .results-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.25rem;
  }
  .results-header h2 {
    margin: 0;
    color: var(--color-fg);
    font-size: 1.4rem;
    font-weight: 750;
    letter-spacing: -0.035em;
  }
  .back-link {
    flex-shrink: 0;
    color: var(--color-link);
    font-size: 0.82rem;
    font-weight: 600;
    text-decoration: none;
  }
  .back-link:hover { color: var(--color-link-hover); text-decoration: none; }
  .post-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 1.35rem;
  }
  .post-card {
    min-width: 0;
    overflow: hidden;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-card);
    transition: transform 180ms cubic-bezier(0.4, 0, 0.2, 1), box-shadow 180ms ease, border-color 180ms ease;
  }
  .post-card:hover {
    transform: translateY(-2px);
    border-color: var(--color-accent);
    box-shadow: var(--shadow-card-hover);
  }
  .post-card-link {
    display: flex;
    flex-direction: column;
    height: 100%;
    color: inherit;
    text-decoration: none;
  }
  .post-card-link:hover { color: inherit; text-decoration: none; }
  .post-card-media { height: 9.5rem; overflow: hidden; background: var(--color-bg-3); }
  .post-card-media img { display: block; width: 100%; height: 100%; object-fit: cover; transition: transform 300ms ease; }
  .post-card:hover .post-card-media img { transform: scale(1.03); }
  .card-placeholder {
    display: grid;
    place-items: center;
    background: linear-gradient(125deg, var(--color-accent) 0%, var(--color-accent-2) 58%, #c084fc 100%);
  }
  .card-placeholder span { color: rgb(255 255 255 / 0.78); font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.12em; }
  .post-card-body { display: flex; flex: 1; flex-direction: column; padding: 1.05rem 1.15rem 1.15rem; }
  .tag-row { display: flex; flex-wrap: wrap; align-items: center; gap: 0.35rem; min-height: 1.45rem; margin-bottom: 0.7rem; }
  .tag-chip {
    padding: 0.18rem 0.52rem;
    border: 1px solid var(--color-accent-soft);
    border-radius: var(--radius-pill);
    background: var(--color-accent-tint);
    color: var(--color-accent-2);
    font-family: var(--font-mono);
    font-size: 0.66rem;
    line-height: 1.3;
  }
  .status-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    margin-left: auto;
    padding: 0.18rem 0.5rem;
    border-radius: var(--radius-pill);
    font-size: 0.65rem;
    font-weight: 600;
    white-space: nowrap;
  }
  .pill-dot { width: 0.35rem; height: 0.35rem; border-radius: 50%; background: currentColor; }
  .status-pill.status-unverified { background: #fef3c7; color: #92400e; }
  .status-pill.status-verified { background: #dcfce7; color: #14532d; }
  .status-pill.status-draft { background: #f3f4f6; color: #4b5563; }
  .status-pill.status-corrected { background: #dbeafe; color: #1e3a8a; }
  .post-card-title {
    display: -webkit-box;
    margin: 0;
    overflow: hidden;
    color: var(--color-fg);
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.35;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }
  .post-card:hover .post-card-title { color: var(--color-accent-2); }
  .post-card-excerpt {
    display: -webkit-box;
    margin: 0.65rem 0 1.1rem;
    overflow: hidden;
    color: var(--color-fg-muted);
    font-family: var(--font-serif);
    font-size: 0.93rem;
    line-height: 1.55;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
  }
  .post-card-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-top: auto;
    padding-top: 0.8rem;
    border-top: 1px solid var(--color-border);
    color: var(--color-fg-subtle);
    font-size: 0.72rem;
  }
  .post-card-foot time { font-variant-numeric: tabular-nums; }
  .read-more { color: var(--color-link); font-weight: 600; }

  @media (max-width: 767px) {
    .page-head { margin-bottom: 2rem; }
    .post-grid { grid-template-columns: 1fr; }
    .results-header { align-items: flex-start; }
  }
</style>

---
import Layout from '../../layouts/Layout.astro';
import { formatDate, getPublishedPosts, STATUS_LABELS } from '../../lib/posts';

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  const investorSet = new Set<string>();
  for (const post of posts) {
    for (const i of post.data.investors) investorSet.add(i);
  }
  return [...investorSet].map(investor => ({
    params: { investor },
    props: {
      investor,
      posts: posts.filter(p => p.data.investors.includes(investor)),
    },
  }));
}

const { investor, posts } = Astro.props;
const timeline = [...posts].sort((a, b) => a.data.date.localeCompare(b.data.date));
const first = timeline[0];
const last = timeline[timeline.length - 1];
---

<Layout title={investor} description={`所有提及 ${investor} 的研究文章`}>
  <header class="page-head">
    <nav class="breadcrumb">
      <a href="/">Home</a>
      <span class="breadcrumb-sep">/</span>
      <a href="/investors/">Investors</a>
      <span class="breadcrumb-sep">/</span>
      <span aria-current="page">{investor}</span>
    </nav>
    <h1>{investor}</h1>
    <p class="lede">{posts.length} 篇研究 · 從 {first?.data.date} 到 {last?.data.date}</p>
  </header>

  <section class="card">
    <h2 class="section-title">立場演變時間軸</h2>
    <ol class="timeline">
      {timeline.map(post => (
        <li class="timeline-item">
          <time>{formatDate(post.data.date)}</time>
          <a href={`/posts/${post.id}/`}>{post.data.title}</a>
          <span class={`status-pill status-${post.data.status}`}><span class="pill-dot"></span>{STATUS_LABELS[post.data.status]?.label}</span>
          <p class="summary">{post.data.summary}</p>
        </li>
      ))}
    </ol>
  </section>
</Layout>

<style>
  .page-head { margin-bottom: 3rem; }
  .breadcrumb {
    display: flex; align-items: center; gap: 0.5rem;
    font-family: var(--font-mono); font-size: 0.75rem;
    color: var(--color-fg-muted); margin-bottom: 1rem;
    text-transform: uppercase; letter-spacing: 0.05em;
  }
  .breadcrumb a { color: var(--color-fg-muted); text-decoration: none; }
  .breadcrumb a:hover { color: var(--color-accent-2); }
  .breadcrumb-sep { color: var(--color-fg-subtle); }
  .breadcrumb [aria-current] { color: var(--color-fg); }
  .page-head h1 {
    font-family: var(--font-sans);
    font-size: clamp(2rem, 5vw, 2.75rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    margin: 0 0 0.5rem;
  }
  .lede { color: var(--color-fg-muted); font-size: 1rem; margin: 0; }

  .card {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 2rem;
    background: var(--color-bg);
  }
  .section-title {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 600;
    margin: 0 0 1.5rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--color-border);
  }

  .timeline {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .timeline-item {
    border-left: 2px solid var(--color-border);
    padding-left: 1.5rem;
    margin-left: 0.5rem;
    padding-bottom: 2rem;
    position: relative;
  }
  .timeline-item:last-child { padding-bottom: 0; }
  .timeline-item::before {
    content: '';
    position: absolute;
    left: -6px;
    top: 0.4rem;
    width: 10px;
    height: 10px;
    background: var(--color-bg);
    border: 2px solid var(--color-accent-2);
    border-radius: 50%;
  }
  .timeline-item time {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-fg-subtle);
    margin-bottom: 0.4rem;
    font-variant-numeric: tabular-nums;
  }
  .timeline-item a {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--color-fg);
    text-decoration: none;
    line-height: 1.35;
    margin-right: 0.5rem;
  }
  .timeline-item a:hover { color: var(--color-accent-2); }
  .timeline-item .summary {
    font-family: var(--font-serif);
    margin: 0.4rem 0 0;
    color: var(--color-fg-2);
    font-size: 0.95rem;
    line-height: 1.55;
  }

  .status-pill {
    display: inline-flex; align-items: center; gap: 0.35rem;
    padding: 0.15rem 0.5rem; border-radius: 100px;
    font-size: 0.7rem; font-weight: 500; text-transform: lowercase; letter-spacing: 0.04em;
    vertical-align: middle;
  }
  .pill-dot { width: 6px; height: 6px; border-radius: 50%; background: currentColor; }
  .status-pill.status-unverified { background: #fef3c7; color: #92400e; }
  .status-pill.status-verified { background: #dcfce7; color: #14532d; }
  .status-pill.status-draft { background: #f3f4f6; color: #4b5563; }
  .status-pill.status-corrected { background: #dbeafe; color: #1e3a8a; }
  @media (prefers-color-scheme: dark) {
    .status-pill.status-unverified { background: #422006; color: #fde68a; }
    .status-pill.status-verified { background: #052e1a; color: #86efac; }
    .status-pill.status-draft { background: #1f2937; color: #d1d5db; }
    .status-pill.status-corrected { background: #1e293b; color: #93c5fd; }
  }
</style>

---
import Layout from '../../layouts/Layout.astro';
import { formatDate, getAllInvestors, getPublishedPosts } from '../../lib/posts';

const posts = await getPublishedPosts();
const investorMap = getAllInvestors(posts);
const investors = [...investorMap.entries()].sort((a, b) => a[0].localeCompare(b[0]));
---

<Layout title="追蹤的投資人 — alpha-lab" description="本站所有追蹤的投資人清單。">
  <header class="page-head">
    <nav class="breadcrumb">
      <a href="/">Home</a>
      <span class="breadcrumb-sep">/</span>
      <span aria-current="page">Investors</span>
    </nav>
    <h1>追蹤的投資人</h1>
    <p class="lede">{investors.length} 位 · 從公開言論、SEC 13F、訪談、社群媒體抓取</p>
  </header>

  <ol class="investor-list">
    {investors.map(([name, list]) => {
      const recent = [...list].sort((a, b) => b.data.date.localeCompare(a.data.date))[0];
      return (
        <li class="investor-row">
          <a href={`/investors/${encodeURIComponent(name)}/`} class="name">{name}</a>
          <span class="count">{list.length} 篇</span>
          <span class="last"><span class="last-label">最近</span> {formatDate(recent.data.date)}</span>
        </li>
      );
    })}
  </ol>
</Layout>

<style>
  .page-head { margin-bottom: 3rem; }
  .breadcrumb {
    display: flex; align-items: center; gap: 0.5rem;
    font-family: var(--font-mono); font-size: 0.75rem;
    color: var(--color-fg-muted); margin-bottom: 1rem;
    text-transform: uppercase; letter-spacing: 0.05em;
  }
  .breadcrumb a { color: var(--color-fg-muted); text-decoration: none; }
  .breadcrumb a:hover { color: var(--color-accent-2); }
  .breadcrumb-sep { color: var(--color-fg-subtle); }
  .breadcrumb [aria-current] { color: var(--color-fg); }
  .page-head h1 {
    font-family: var(--font-sans);
    font-size: clamp(2rem, 5vw, 2.75rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    margin: 0 0 0.5rem;
  }
  .lede { color: var(--color-fg-muted); font-size: 1rem; margin: 0; }

  .investor-list { list-style: none; padding: 0; margin: 0; }
  .investor-row {
    display: grid;
    grid-template-columns: 1fr auto auto;
    align-items: baseline;
    gap: 0.5rem 1.25rem;
    padding: 1.1rem 0;
    border-bottom: 1px dashed var(--color-border);
    transition: background-color 120ms ease, padding-left 120ms ease;
  }
  .investor-row:hover { background: var(--color-bg-2); padding-left: 0.5rem; }
  .investor-row .name {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--color-fg);
    text-decoration: none;
  }
  .investor-row .name:hover { color: var(--color-accent-2); }
  .investor-row .count {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-fg-muted);
    background: var(--color-bg-2);
    padding: 0.15rem 0.5rem;
    border-radius: 100px;
    font-variant-numeric: tabular-nums;
  }
  .investor-row .last {
    font-size: 0.8rem;
    color: var(--color-fg-subtle);
    font-variant-numeric: tabular-nums;
  }
  .last-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-right: 0.4rem;
  }
</style>

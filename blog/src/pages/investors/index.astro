---
import Layout from '../../layouts/Layout.astro';
import { formatDate, getAllInvestors, getPublishedPosts } from '../../lib/posts';

const posts = await getPublishedPosts();
const investorMap = getAllInvestors(posts);
const investors = [...investorMap.entries()].sort((a, b) => b[1].length - a[1].length || a[0].localeCompare(b[0]));
---

<Layout title="追蹤的投資人 — alpha-lab" description="本站所有追蹤的投資人清單。">
  <header class="page-head">
    <nav class="breadcrumb" aria-label="麵包屑">
      <a href="/">Home</a>
      <span class="breadcrumb-sep">/</span>
      <span aria-current="page">Investors</span>
    </nav>
    <p class="page-kicker">Investor directory</p>
    <h1>追蹤的投資人</h1>
    <p class="lede">{investors.length} 位 · 從公開言論、SEC 13F、訪談、社群媒體抓取</p>
  </header>

  <section class="directory" aria-labelledby="investor-directory-heading">
    <header class="directory-head">
      <div>
        <p class="section-kicker">Browse by person</p>
        <h2 id="investor-directory-heading">研究對象</h2>
      </div>
      <a href="/" class="back-link">回到首頁 <span aria-hidden="true">→</span></a>
    </header>
    <ul class="investor-grid">
      {investors.map(([name, list]) => {
        const recent = [...list].sort((a, b) => b.data.date.localeCompare(a.data.date))[0];
        return (
          <li>
            <a href={`/investors/${encodeURIComponent(name)}`} class="investor-card">
              <span class="investor-card-top">
                <span class="investor-avatar" aria-hidden="true">{name.slice(0, 1).toUpperCase()}</span>
                <span class="investor-count">{list.length} 篇</span>
              </span>
              <strong class="investor-name">{name}</strong>
              <span class="investor-recent"><span>最近更新</span>{formatDate(recent.data.date)}</span>
            </a>
          </li>
        );
      })}
    </ul>
  </section>
</Layout>

<style>
  /* 頁首 */
  .page-head { margin-bottom: 2.5rem; }
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
    color: var(--color-fg-muted);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  .breadcrumb a { color: var(--color-fg-muted); text-decoration: none; }
  .breadcrumb a:hover { color: var(--color-accent-2); }
  .breadcrumb-sep { color: var(--color-fg-subtle); }
  .breadcrumb [aria-current] { color: var(--color-fg); }
  .page-kicker, .section-kicker {
    color: var(--color-accent-2);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .page-kicker { margin: 0 0 0.4rem; }
  .page-head h1 {
    margin: 0 0 0.5rem;
    color: var(--color-fg);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.05em;
    line-height: 1.1;
  }
  .lede { margin: 0; color: var(--color-fg-muted); font-size: 1rem; }

  /* 投資人目錄 */
  .directory {
    padding: clamp(1rem, 3vw, 1.75rem);
    background: var(--color-bg-2);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-card);
  }
  .directory-head {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.25rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--color-border);
  }
  .section-kicker { margin: 0 0 0.2rem; }
  .directory-head h2 {
    margin: 0;
    color: var(--color-fg);
    font-size: 1.35rem;
    font-weight: 750;
    letter-spacing: -0.035em;
  }
  .back-link {
    flex-shrink: 0;
    color: var(--color-link);
    font-size: 0.82rem;
    font-weight: 600;
    text-decoration: none;
  }
  .back-link:hover { color: var(--color-link-hover); text-decoration: none; }
  .investor-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 0.85rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .investor-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    min-height: 8.5rem;
    padding: 1rem;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-card);
    color: var(--color-fg);
    text-decoration: none;
    transition: transform 150ms ease, border-color 150ms ease, box-shadow 150ms ease;
  }
  .investor-card:hover {
    transform: translateY(-2px);
    border-color: var(--color-accent);
    box-shadow: var(--shadow-card-hover);
    color: var(--color-fg);
    text-decoration: none;
  }
  .investor-card-top { display: flex; align-items: center; justify-content: space-between; gap: 0.5rem; }
  .investor-avatar {
    display: grid;
    place-items: center;
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    background: var(--color-accent-tint);
    color: var(--color-accent-2);
    font-size: 0.8rem;
    font-weight: 800;
  }
  .investor-count {
    padding: 0.18rem 0.5rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-pill);
    background: var(--color-bg-2);
    color: var(--color-fg-muted);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-variant-numeric: tabular-nums;
  }
  .investor-name {
    color: var(--color-fg);
    font-size: 1.02rem;
    letter-spacing: -0.015em;
  }
  .investor-card:hover .investor-name { color: var(--color-accent-2); }
  .investor-recent {
    display: flex;
    justify-content: space-between;
    gap: 0.5rem;
    margin-top: auto;
    padding-top: 0.65rem;
    border-top: 1px solid var(--color-border);
    color: var(--color-fg-subtle);
    font-size: 0.72rem;
    font-variant-numeric: tabular-nums;
  }
  .investor-recent span { color: var(--color-fg-muted); }

  @media (max-width: 767px) {
    .page-head { margin-bottom: 2rem; }
    .directory-head { align-items: flex-start; }
    .investor-grid { grid-template-columns: repeat(auto-fill, minmax(190px, 1fr)); }
  }
</style>

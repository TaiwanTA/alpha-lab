---
import Layout from '../../layouts/Layout.astro';
import { getArchiveYears, getPublishedPosts } from '../../lib/posts';

const posts = await getPublishedPosts();
const yearMap = getArchiveYears(posts);
const years = [...yearMap.entries()].sort((a, b) => b[0].localeCompare(a[0]));
---

<Layout title="Archive — alpha-lab" description="依月份瀏覽所有文章">
  <header class="page-head">
    <nav class="breadcrumb">
      <a href="/">Home</a>
      <span class="breadcrumb-sep">/</span>
      <span aria-current="page">Archive</span>
    </nav>
    <h1>Archive</h1>
    <p class="lede">{posts.length} 篇 · 從 {years[years.length - 1]?.[0]} 到 {years[0]?.[0]}</p>
  </header>

  {years.map(([year, list]) => (
    <section class="year-section">
      <h2 class="year-title">{year} <span class="count">{list.length} 篇</span></h2>
      <ul class="archive-list">
        {[...list].sort((a, b) => b.data.date.localeCompare(a.data.date)).map(post => (
          <li>
            <time>{post.data.date.slice(5)}</time>
            <a href={`/posts/${post.id}/`}>{post.data.title}</a>
          </li>
        ))}
      </ul>
    </section>
  ))}
</Layout>

<style>
  .page-head { margin-bottom: 3rem; }
  .breadcrumb {
    display: flex; align-items: center; gap: 0.5rem;
    font-family: var(--font-mono); font-size: 0.75rem;
    color: var(--color-fg-muted); margin-bottom: 1rem;
    text-transform: uppercase; letter-spacing: 0.05em;
  }
  .breadcrumb a { color: var(--color-fg-muted); text-decoration: none; }
  .breadcrumb a:hover { color: var(--color-accent-2); }
  .breadcrumb-sep { color: var(--color-fg-subtle); }
  .breadcrumb [aria-current] { color: var(--color-fg); }
  .page-head h1 {
    font-family: var(--font-sans);
    font-size: clamp(2rem, 5vw, 2.75rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    margin: 0 0 0.5rem;
  }
  .lede { color: var(--color-fg-muted); font-size: 1rem; margin: 0; }

  .year-section { margin-bottom: 3rem; }
  .year-title {
    font-family: var(--font-sans);
    font-size: 1.6rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0 0 1rem;
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
  }
  .year-title .count {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-fg-muted);
    background: var(--color-bg-2);
    padding: 0.1rem 0.5rem;
    border-radius: 100px;
    border: 1px solid var(--color-border);
  }
  .archive-list { list-style: none; padding: 0; margin: 0; }
  .archive-list li {
    display: grid;
    grid-template-columns: 4rem 1fr;
    gap: 1rem;
    align-items: baseline;
    padding: 0.5rem 0;
    border-bottom: 1px dashed var(--color-border);
  }
  .archive-list time {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-fg-muted);
    font-variant-numeric: tabular-nums;
  }
  .archive-list a {
    font-family: var(--font-serif);
    color: var(--color-fg);
    font-size: 1rem;
    text-decoration: none;
  }
  .archive-list a:hover { color: var(--color-accent-2); }
</style>

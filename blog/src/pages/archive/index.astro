---
import Layout from '../../layouts/Layout.astro';
import { getArchiveYears, getPublishedPosts } from '../../lib/posts';

const posts = await getPublishedPosts();
const yearMap = getArchiveYears(posts);
const years = [...yearMap.entries()].sort((a, b) => b[0].localeCompare(a[0]));
---

<Layout title="Archive — alpha-lab" description="依月份瀏覽所有文章">
  <header class="page-header">
    <h1>Archive</h1>
    <p>{posts.length} 篇 · 從 {years[years.length - 1]?.[0]} 到 {years[0]?.[0]}</p>
  </header>

  {years.map(([year, list]) => (
    <section class="year-section">
      <h2>{year} <span class="count">({list.length})</span></h2>
      <ul class="archive-list">
        {[...list].sort((a, b) => b.data.date.localeCompare(a.data.date)).map(post => (
          <li>
            <time>{post.data.date.slice(5)}</time>
            <a href={`/posts/${post.id}/`}>{post.data.title}</a>
          </li>
        ))}
      </ul>
    </section>
  ))}
</Layout>

<style>
  .page-header { margin-bottom: 2rem; }
  .page-header h1 { font-size: 2rem; margin: 0 0 0.5rem; }
  .page-header p { color: var(--color-muted); margin: 0; }
  .year-section { margin-bottom: 2rem; }
  .year-section h2 {
    font-size: 1.5rem;
    margin: 0 0 1rem;
    padding-top: 0;
    border-top: 0;
  }
  .count { color: var(--color-muted); font-size: 1rem; font-weight: 400; }
  .archive-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .archive-list li {
    padding: 0.4rem 0;
    border-bottom: 1px solid var(--color-border);
    display: flex;
    gap: 1rem;
    align-items: baseline;
  }
  .archive-list time {
    color: var(--color-muted);
    font-size: 0.85rem;
    flex: 0 0 4rem;
  }
  .archive-list a {
    color: var(--color-fg);
    text-decoration: none;
    font-weight: 500;
  }
  .archive-list a:hover { color: var(--color-link); }
</style>

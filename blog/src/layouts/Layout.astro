---
import { ClientRouter } from 'astro:transitions';
import '../styles/tokens.css';

interface Props {
  title?: string;
  description?: string;
  ogType?: 'article' | 'website';
  publishedDate?: string;
  modifiedDate?: string;
  tags?: string[];
  noindex?: boolean;
}

const { title, description, ogType, publishedDate, modifiedDate, tags, noindex } = Astro.props;

const SITE = 'alpha-lab';
const FULL_TITLE = title ? `${title} — ${SITE}` : `${SITE} — 知名投資人研究`;
const DESC = description ?? '研究公開投資人的言論、論點、與市場直覺。每篇明示來源、可重複查證或標為未驗證';
const URL_VAL = new URL(Astro.url.pathname, Astro.site).toString();
const OG_TYPE = ogType ?? 'website';
---

<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={DESC} />
    <title>{FULL_TITLE}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="alternate" type="application/rss+xml" title="alpha-lab — RSS Feed" href="/feed.xml" />
    <link rel="alternate" type="application/atom+xml" title="alpha-lab — Atom" href="/feed.atom.xml" />
    <link rel="alternate" type="application/json" title="alpha-lab — JSON Feed" href="/feed.json" />
    <link rel="canonical" href={URL_VAL} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}

    <meta property="og:type" content={OG_TYPE} />
    <meta property="og:title" content={title ?? SITE} />
    <meta property="og:description" content={DESC} />
    <meta property="og:url" content={URL_VAL} />
    <meta property="og:site_name" content={SITE} />
    <meta property="og:locale" content="zh_TW" />
    {publishedDate && <meta property="article:published_time" content={publishedDate} />}
    {modifiedDate && <meta property="article:modified_time" content={modifiedDate} />}
    {tags?.map((t: string) => <meta property="article:tag" content={t} />)}

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title ?? SITE} />
    <meta name="twitter:description" content={DESC} />

    <script
      type="application/ld+json"
      set:html={JSON.stringify(
      OG_TYPE === 'article'
? {
        '@context': 'https://schema.org',
        '@type': 'BlogPosting',
        'headline': title,
        'description': DESC,
        'datePublished': publishedDate,
        'dateModified': modifiedDate ?? publishedDate,
        'keywords': tags?.join(', '),
        'author': { '@type': 'Person', 'name': 'alpha-lab agent' },
        'publisher': { '@type': 'Organization', 'name': SITE },
        'mainEntityOfPage': { '@type': 'WebPage', '@id': URL_VAL },
      }
: {
        '@context': 'https://schema.org',
        '@type': 'WebSite',
        'name': SITE,
        'url': Astro.site?.toString(),
        'description': DESC,
        'potentialAction': {
          '@type': 'SearchAction',
          'target': '/search?q={search_term_string}',
          'query-input': 'required name=search_term_string',
        },
      },
    )}
    ></script>

    <ClientRouter />

    <style is:global>
      *, *::before, *::after { box-sizing: border-box; }

      html {
        font-size: 16px;
        scroll-behavior: smooth;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        text-rendering: optimizeLegibility;
      }

      body {
        margin: 0;
        font-family: var(--font-sans);
        color: var(--color-fg);
        background: var(--color-bg);
        line-height: 1.6;
        font-feature-settings: 'kern', 'liga', 'calt';
      }

      a {
        color: var(--color-link);
        text-decoration: none;
        transition: color 120ms ease;
      }
      a:hover { color: var(--color-link-hover); text-decoration: underline; text-underline-offset: 2px; }

      ::selection {
        background: var(--color-accent-soft);
        color: var(--color-fg);
      }

      /* ───────── View Transitions ───────── */
      @keyframes vt-fade-out { to { opacity: 0; transform: translateY(-6px); } }
      @keyframes vt-fade-in { from { opacity: 0; transform: translateY(8px); } }
      @keyframes vt-shrink-out { to { opacity: 0; transform: scale(0.96); } }
      @keyframes vt-grow-in { from { opacity: 0; transform: scale(1.02); } }

      ::view-transition-old(root),
      ::view-transition-new(root) {
        animation-duration: 280ms;
        animation-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
      }
      ::view-transition-old(root) { animation-name: vt-fade-out; }
      ::view-transition-new(root) { animation-name: vt-fade-in; }

      /* Shared element: post-card-title (list) ↔ .post-title (article) */
      ::view-transition-group(post-title) { animation-duration: 360ms; }
      ::view-transition-old(post-title) { animation-duration: 360ms; animation-name: vt-shrink-out; }
      ::view-transition-new(post-title) { animation-duration: 360ms; animation-name: vt-grow-in; }

      @media (prefers-reduced-motion: reduce) {
        ::view-transition-old(root),
        ::view-transition-new(root),
        ::view-transition-old(post-title),
        ::view-transition-new(post-title) {
          animation-duration: 0.001ms !important;
        }
        html { scroll-behavior: auto; }
        *, *::before, *::after {
          animation-duration: 0.01ms !important;
          transition-duration: 0.01ms !important;
        }
      }

      /* Skip-to-content */
      .skip-link {
        position: absolute;
        left: -10000px;
        top: auto;
        width: 1px;
        height: 1px;
        overflow: hidden;
      }
      .skip-link:focus {
        position: fixed;
        top: 1rem;
        left: 1rem;
        width: auto;
        height: auto;
        background: var(--color-accent-2);
        color: white;
        padding: 0.5rem 1rem;
        border-radius: var(--radius-md);
        text-decoration: none;
        z-index: 9999;
      }

      /* ───────── Navigation ───────── */
      nav.site-nav {
        max-width: var(--max-width-wide);
        margin: 0 auto;
        padding: 1.25rem 2rem;
        display: flex;
        flex-wrap: wrap;
        gap: 1.5rem;
        align-items: center;
        font-size: 0.9rem;
        background: var(--color-bg);
      }
      nav.site-nav a.brand {
        font-weight: 700;
        font-size: 1.1rem;
        color: var(--color-fg);
        text-decoration: none;
        letter-spacing: -0.01em;
      }
      nav.site-nav a { color: var(--color-fg-muted); text-decoration: none; transition: color 120ms ease; }
      nav.site-nav a:hover { color: var(--color-fg); text-decoration: none; }
      .nav-spacer { flex: 1; }
      nav.site-nav .nav-cta {
        color: var(--color-accent-2);
        font-weight: 500;
      }

      main.site-main {
        max-width: var(--max-width-wide);
        margin: 0 auto;
        padding: 1rem 2rem 6rem;
      }

      footer.site-footer {
        max-width: var(--max-width-wide);
        margin: 0 auto;
        padding: 3rem 2rem 4rem;
        border-top: 1px solid var(--color-border);
        color: var(--color-fg-muted);
        font-size: 0.9rem;
        display: grid;
        grid-template-columns: 1fr;
        gap: 1rem;
      }
      @media (min-width: 768px) {
        footer.site-footer { grid-template-columns: 2fr 1fr; align-items: start; }
      }
      footer.site-footer .tagline {
        font-family: var(--font-serif);
        font-style: italic;
        font-size: 1rem;
        color: var(--color-fg-2);
        margin: 0;
      }
      footer.site-footer .links {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem 1.5rem;
        font-size: 0.85rem;
      }
      footer.site-footer .disclaimer {
        grid-column: 1 / -1;
        margin-top: 1rem;
        padding-top: 1.5rem;
        border-top: 1px dashed var(--color-border);
        font-size: 0.8rem;
        color: var(--color-fg-subtle);
      }
    </style>
  </head>

  <body>
    <a class="skip-link" href="#main">略過導航,直接到內容</a>

    <nav class="site-nav">
      <a class="brand" href="/">alpha-lab</a>
      <a href="/tags/">Tags</a>
      <a href="/archive/">Archive</a>
      <a href="/investors/">Investors</a>
      <a href="/methodology/">Methodology</a>
      <a href="/about/">About</a>
      <span class="nav-spacer"></span>
      <a href="/search/">Search</a>
      <a href="/feed.xml" class="nav-cta">RSS</a>
    </nav>

    <main id="main" class="site-main">
      <slot />
    </main>

    <footer class="site-footer">
      <p class="tagline">研究公開投資人的言論、檢驗論點、模擬下注。</p>
      <div class="links">
        <a href="/about/">關於這個站</a>
        <a href="/methodology/">方法論</a>
        <a href="/feed.xml">RSS</a>
        <a href="/feed.atom.xml">Atom</a>
        <a href="/feed.json">JSON Feed</a>
        <a href="/investors/">投資人清單</a>
      </div>
      <p class="disclaimer">
        alpha-lab 不構成投資建議。所有 investmentClaim 文章需要讀者自行查證並承擔風險。
        每篇文章依其來源驗證狀態顯示 <code>draft / unverified / verified / corrected</code> 標籤。
      </p>
    </footer>
  </body>
</html>

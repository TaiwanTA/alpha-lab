---
const { title } = Astro.props;
---

<!doctype html>
<html lang="zh-TW">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="研究知名投資人的觀點、論點、與市場直覺" />
    <title>{title}</title>
  </head>
  <body>
    <nav>
      <a href="/">Home</a>
    </nav>
    <main>
      <slot />
    </main>
  </body>
</html>

<style is:global>










  :root {
    --max-width: 720px;
    --color-fg: #111;
    --color-muted: #666;
    --color-border: #eee;
  }
  * { box-sizing: border-box; }
  body {
    margin: 0;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
    color: var(--color-fg);
    line-height: 1.6;
    background: #fff;
  }
  nav {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 1.5rem 1.5rem 0;
    font-size: 0.95rem;
  }
  nav a { color: var(--color-muted); text-decoration: none; }
  nav a:hover { color: var(--color-fg); }
  main {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }










</style>

---
const { title, description, ogType, publishedDate, modifiedDate, tags, noindex } = Astro.props;

const SITE = 'alpha-lab';
const FULL_TITLE = title ? `${title} — ${SITE}` : `${SITE} — 知名投資人研究`;
const DESC = description ?? '研究知名投資人的觀點、論點、與市場直覺。每篇明示來源、可重複查證或標為未驗證';
const URL_VAL = new URL(Astro.url.pathname, Astro.site).toString();
const OG_TYPE = ogType ?? 'website';
---
<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={DESC} />
    <title>{FULL_TITLE}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="alternate" type="application/rss+xml" title="alpha-lab — RSS Feed" href="/feed.xml" />
    <link rel="alternate" type="application/atom+xml" title="alpha-lab — Atom" href="/feed.atom.xml" />
    <link rel="alternate" type="application/json" title="alpha-lab — JSON Feed" href="/feed.json" />
    <link rel="canonical" href={URL_VAL} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}

    <!-- Open Graph -->
    <meta property="og:type" content={OG_TYPE} />
    <meta property="og:title" content={title ?? SITE} />
    <meta property="og:description" content={DESC} />
    <meta property="og:url" content={URL_VAL} />
    <meta property="og:site_name" content={SITE} />
    <meta property="og:locale" content="zh_TW" />
    {publishedDate && <meta property="article:published_time" content={publishedDate} />}
    {modifiedDate && <meta property="article:modified_time" content={modifiedDate} />}
    {tags?.map((t: string) => <meta property="article:tag" content={t} />)}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title ?? SITE} />
    <meta name="twitter:description" content={DESC} />

    <!-- JSON-LD -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify(
        OG_TYPE === 'article'
          ? {
              '@context': 'https://schema.org',
              '@type': 'BlogPosting',
              'headline': title,
              'description': DESC,
              'datePublished': publishedDate,
              'dateModified': modifiedDate ?? publishedDate,
              'keywords': tags?.join(', '),
              'author': { '@type': 'Person', 'name': 'alpha-lab agent' },
              'publisher': { '@type': 'Organization', 'name': SITE },
              'mainEntityOfPage': { '@type': 'WebPage', '@id': URL_VAL },
            }
          : {
              '@context': 'https://schema.org',
              '@type': 'WebSite',
              'name': SITE,
              'url': Astro.site?.toString(),
              'description': DESC,
              'potentialAction': {
                '@type': 'SearchAction',
                'target': '/search?q={search_term_string}',
                'query-input': 'required name=search_term_string',
              },
            },
      )}
    >
    </script>

    <style is:global>
      :root {
        --max-width: 720px;
        --color-fg: #111;
        --color-bg: #fff;
        --color-muted: #666;
        --color-border: #eee;
        --color-link: #1d4ed8;
        --color-code-bg: #f3f4f6;
        --color-quote-border: #d1d5db;
        --font-base: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, 'PingFang TC', 'Microsoft JhengHei', sans-serif;
        --font-serif: 'Source Han Serif TC', 'Noto Serif CJK TC', 'Times New Roman', serif;
      }
      @media (prefers-color-scheme: dark) {
        :root {
          --color-fg: #e5e7eb;
          --color-bg: #0f1115;
          --color-muted: #9ca3af;
          --color-border: #1f2937;
          --color-link: #93c5fd;
          --color-code-bg: #1f2937;
          --color-quote-border: #374151;
        }
      }
      * { box-sizing: border-box; }
      html { font-size: 16px; scroll-behavior: smooth; }
      body {
        margin: 0;
        font-family: var(--font-base);
        color: var(--color-fg);
        background: var(--color-bg);
        line-height: 1.6;
      }
      a { color: var(--color-link); }
      a:hover { text-decoration: underline; }

      /* Skip-to-content */
      .skip-link {
        position: absolute;
        left: -10000px;
        top: auto;
        width: 1px;
        height: 1px;
        overflow: hidden;
      }
      .skip-link:focus {
        position: static;
        width: auto;
        height: auto;
        background: var(--color-link);
        color: white;
        padding: 0.5rem 1rem;
        text-decoration: none;
      }

      nav.site-nav {
        max-width: 1080px;
        margin: 0 auto;
        padding: 1rem 1.5rem;
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        align-items: center;
        font-size: 0.95rem;
        border-bottom: 1px solid var(--color-border);
      }
      nav.site-nav a.brand {
        font-weight: 700;
        color: var(--color-fg);
        text-decoration: none;
        margin-right: 0.5rem;
      }
      nav.site-nav a { color: var(--color-muted); text-decoration: none; }
      nav.site-nav a:hover { color: var(--color-fg); text-decoration: underline; }
      .nav-spacer { flex: 1; }
      .nav-search {
        background: transparent;
        border: 1px solid var(--color-border);
        color: var(--color-fg);
        padding: 0.25rem 0.5rem;
        border-radius: 4px;
        font-size: 0.9rem;
      }

      main, .site-main {
        max-width: 1080px;
        margin: 0 auto;
        padding: 2rem 1.5rem 4rem;
      }
      .content-wrap {
        max-width: var(--max-width);
        margin: 0 auto;
      }

      @media (prefers-reduced-motion: reduce) {
        html { scroll-behavior: auto; }
        *, *::before, *::after { animation-duration: 0.01ms !important; transition-duration: 0.01ms !important; }
      }
    </style>
  </head>
  <body>
    <a class="skip-link" href="#main">略過導航,直接到內容</a>

    <nav class="site-nav">
      <a class="brand" href="/">alpha-lab</a>
      <a href="/tags/">Tags</a>
      <a href="/archive/">Archive</a>
      <a href="/investors/">Investors</a>
      <a href="/methodology/">Methodology</a>
      <a href="/about/">About</a>
      <span class="nav-spacer"></span>
      <a href="/search/">Search</a>
      <a href="/feed.xml">RSS</a>
    </nav>

    <main id="main" class="site-main">
      <slot />
    </main>

    <footer style="max-width:1080px;margin:0 auto;padding:1.5rem;border-top:1px solid var(--color-border);color:var(--color-muted);font-size:.85rem;">
      <div class="content-wrap">
        <p>
          alpha-lab · 研究公開投資人言論、檢驗論點、模擬下注。
          <a href="/about/">關於這個站</a> ·
          <a href="/methodology/">方法論</a> ·
          <a href="/feed.xml">RSS</a>
        </p>
        <p style="margin-top:.5rem;">
          本文不構成投資建議。所有 investmentClaim 文章需要讀者自行查證。
        </p>
      </div>
    </footer>
  </body>
</html>
